FLASK_ENV=development
API_HOST=0.0.0.0
API_PORT=5000
REDIS_URL=redis://localhost:6379/0
STORAGE_ROOT=../data
PADDLE_OCR_MODE=python_api
PADDLE_OCR_BASE_URL=http://192.168.1.2:8080
PADDLE_OCR_SERVER_URL=http://192.168.1.2:8080/v1
PADDLE_OCR_API_MODEL_NAME=PaddleOCR-VL-1.5-0.9B
PADDLE_OCR_API_KEY=EMPTY
PADDLE_OCR_MAX_CONCURRENCY=32
PADDLE_OCR_TIMEOUT_SECONDS=180
PADDLE_OCR_FILE_MODE=base64
VLLM_BASE_URL=http://192.168.1.2:9000/v1
VLLM_API_KEY=EMPTY
VLLM_MODEL=Qwen3-8B
VLLM_TIMEOUT_SECONDS=180
VLLM_ENABLE_THINKING=false
OCR_CONCURRENCY=1
LLM_CONCURRENCY=4
MAX_CHUNK_CHARS=2400
RELATION_SPLIT_MODE=small_section
RELATION_BATCH_SIZE=1
RELATION_MAX_BATCH_TOKENS=2500
RELATION_INCLUDE_PARENT_TITLE=true
SENTENCE_STAGE_LIMIT=12
PAGE_STAGE_LIMIT=12
WORKER_POLL_SECONDS=2
