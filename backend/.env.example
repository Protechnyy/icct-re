# API
FLASK_ENV=development
API_HOST=0.0.0.0
API_PORT=5000

# Storage and queue
REDIS_URL=redis://localhost:6379/0
STORAGE_ROOT=../data

# PaddleOCR-VL
PADDLE_OCR_MODE=python_api
PADDLE_OCR_BASE_URL=http://127.0.0.1:8118
PADDLE_OCR_SERVER_URL=http://127.0.0.1:8118/v1
PADDLE_OCR_API_MODEL_NAME=PaddleOCR-VL-1.5-0.9B
PADDLE_OCR_API_KEY=EMPTY
PADDLE_OCR_TIMEOUT_SECONDS=180
PADDLE_OCR_FILE_MODE=base64

# vLLM / Qwen
VLLM_BASE_URL=http://127.0.0.1:8000/v1
VLLM_API_KEY=EMPTY
VLLM_MODEL=Qwen/Qwen3-32B-AWQ
VLLM_TIMEOUT_SECONDS=180
VLLM_ENABLE_THINKING=false

# Pipeline concurrency and output limits
OCR_CONCURRENCY=1
LLM_CONCURRENCY=4
MAX_CHUNK_CHARS=2400
SENTENCE_STAGE_LIMIT=12
PAGE_STAGE_LIMIT=12
WORKER_POLL_SECONDS=2

# Skill4RE
SKILL4RE_BACKEND=vllm
SKILL4RE_MODEL=Qwen/Qwen3-32B-AWQ
SKILL4RE_SKILLS_DIR=../skill4re/skill4re/skills
SKILL4RE_ROUTE_CACHE_PATH=../data/tmp/skill4re_route_cache.json
SKILL4RE_CHUNK_TRIGGER=1200
SKILL4RE_CHUNK_BUDGET=900
SKILL4RE_MAX_WORKERS=4
SKILL4RE_FAST_MODE=false
SKILL4RE_SKIP_COREF=false
